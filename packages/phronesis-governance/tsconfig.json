{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Node16",
		"moduleResolution": "Node16",
		"strict": true,
		"erasableSyntaxOnly": true,
		"skipLibCheck": true,
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"types": ["node"],
		"paths": {
			"metis": ["./src/metis-api-shim.d.ts"]
		}
	},
	"include": ["src/**/*.ts"],
	"exclude": ["dist", "node_modules"]
}